# Database (PostgreSQL). On Vercel: add from Storage or use Neon/Supabase connection string.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth: generate with `openssl rand -base64 32`
NEXTAUTH_SECRET="your-secret-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# For production on Vercel, set NEXTAUTH_URL to your deployment URL (e.g. https://your-app.vercel.app)
