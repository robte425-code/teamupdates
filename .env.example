# Database (PostgreSQL). On Vercel: add from Storage or use Neon/Supabase connection string.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
# Optional but recommended for Prisma Migrate/Introspection against Neon:
# use the direct (non-pooled) URL for schema operations.
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth: generate with `openssl rand -base64 32`
NEXTAUTH_SECRET="your-secret-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# For production, set NEXTAUTH_URL to your deployment URL (e.g. https://your-app.vercel.app)

# Microsoft 365 / Azure AD (required for sign-in)
# Register an app at https://portal.azure.com → Azure Active Directory → App registrations
# Redirect URI: https://your-domain.com/api/auth/callback/azure-ad (and http://localhost:3000/api/auth/callback/azure-ad for local)
AZURE_AD_CLIENT_ID="your-client-id"
AZURE_AD_CLIENT_SECRET="your-client-secret"
AZURE_AD_TENANT_ID="your-tenant-id"

# Allowed email domains, comma-separated (e.g. team-voc.com and tenant.onmicrosoft.com from Azure)
ALLOWED_DOMAIN="team-voc.com,teamvoc.onmicrosoft.com"

# Site owners (admins): comma-separated emails. These users get access to Manage (updates & key dates).
# Everyone else in your Microsoft 365 org can sign in as members (view home page only).
ADMIN_EMAILS="admin@yourcompany.com,owner@yourcompany.com"

# Resend (welcome emails, inactive-user reminders). https://resend.com
RESEND_API_KEY=""
# REQUIRED for real recipients: verify your domain in Resend, then set From to an address on that domain.
# Without this, Resend only allows sending to your own account email (testing mode).
# EMAIL_FROM="TEAM Dashboard <noreply@your-verified-domain.com>"
# Optional legacy default (testing only — not for teamvoc.com recipients):
# EMAIL_FROM="Team Voc <onboarding@resend.dev>"

# Secret for /api/cron/reminders (Vercel Cron sends Authorization: Bearer <CRON_SECRET>).
CRON_SECRET=""

# URL of the TEAM HR app (used by the "HR" link in the top navigation).
NEXT_PUBLIC_HR_URL="https://team-hr.vercel.app"
NEXT_PUBLIC_REQUESTS_URL="https://team-requests.vercel.app"
NEXT_PUBLIC_VOC_HOTLINE_URL="https://voc-hotline-nine.vercel.app"
NEXT_PUBLIC_PAYROLL_URL="https://team-payroll.vercel.app/my-leave.html"
NEXT_PUBLIC_UPDATES_URL="https://teamvoc-updates.vercel.app"

# Neon API key for Backup hub live snapshot status (Updates admin only).
# Create at https://console.neon.tech/app/settings/api-keys
NEON_API_KEY=""

# Shared secret for Updates to call each app's /api/internal/* routes (same value on every TEAM app).
TEAM_INTERNAL_ACCESS_SECRET=""

# SharePoint site used for TEAM database backups (Microsoft Graph app-only access).
# Example: https://yourtenant.sharepoint.com/sites/TEAM
# Azure app registration needs application permissions: Sites.ReadWrite.All, Files.ReadWrite.All
# HR and Voc hotline also need SHAREPOINT_SITE_URL (same value) for zip backups.
# Requests, Payroll, Dashboard, HR, and Voc hotline each upload backups directly to SharePoint.
SHAREPOINT_SITE_URL=""
