generator client {
  provider      = "prisma-client-js"
  // Vercel serverless uses Amazon Linux / RHEL-style OpenSSL; CI (Ubuntu) uses Debian.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("member") // "admin" | "member"
  createdAt DateTime @default(now())
}

model Update {
  id        String   @id @default(cuid())
  date      DateTime // when the item was posted
  title     String
  body      String
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model KeyDate {
  id           String    @id @default(cuid())
  dateType     String    @default("due") // "due" = single due date; "event" = start/end
  eventDate    DateTime  // due date, or event start
  eventEndDate DateTime? // event end (only when dateType === "event")
  title        String
  body         String
  deleteType   String    @default("manual") // "auto" = remove 1 day after expiry; "manual" = hide when expired, delete only by user
  createdAt    DateTime  @default(now())
}

model TickerItem {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())
}

model PageVisit {
  id        String   @id @default(cuid())
  userId    String?
  userName  String?
  userEmail String?
  path      String
  visitedAt DateTime @default(now())
}
