generator client {
  provider      = "prisma-client-js"
  // Vercel serverless uses Amazon Linux / RHEL-style OpenSSL; CI (Ubuntu) uses Debian.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("member") // "admin" | "member"
  createdAt DateTime @default(now())
}

model Update {
  id              String   @id @default(cuid())
  date            DateTime // when the item was posted
  title           String
  body            String
  archived        Boolean  @default(false)
  createdAt       DateTime @default(now())
  createdByName   String?
  createdByEmail  String?
}

model KeyDate {
  id              String    @id @default(cuid())
  dateType        String    @default("due") // "due" = single due date; "event" = start/end
  eventDate       DateTime  // due date, or event start
  eventEndDate    DateTime? // event end (only when dateType === "event")
  title           String
  body            String
  archived        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  createdByName   String?
  createdByEmail  String?
}

/// Singleton row id `"default"` — NEW / SOON badge windows (days).
model KeyDateBadgeSettings {
  id            String @id @default("default")
  newBadgeDays  Int    @default(3)
  soonBadgeDays Int    @default(7)
}

model TickerItem {
  id        String   @id @default(cuid())
  text      String
  /// When false, hidden from header ticker (still listed on manage page).
  displayed Boolean  @default(true)
  createdAt DateTime @default(now())
}

/// Singleton row id `"default"` — horizontal scroll speed for the header ticker (px/s).
model TickerSettings {
  id                   String @id @default("default")
  scrollSpeedPxPerSec Int    @default(40)
}

model BirthdayEntry {
  id        String   @id @default(cuid())
  name      String
  month     Int
  day       Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Singleton id `"default"` — inactive-user reminder emails (dashboard `/` visits).
model ReminderSettings {
  id                     String @id @default("default")
  /// No `/` visit for this many days ⇒ eligible for a reminder (Pacific calendar sense via app logic).
  inactiveDaysThreshold Int    @default(7)
  emailSubject          String @default("Reminder: TEAM dashboard")
  /// Placeholders: {{firstName}}, {{name}}, {{email}}, {{inactiveDays}}, {{dashboardUrl}}
  emailBody             String @default("Hi {{firstName}},\n\nWe have not seen you on the TEAM dashboard for {{inactiveDays}} days.\n\nPlease visit: {{dashboardUrl}}\n\nThank you.")
}

model ReminderRecipient {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String?
  enabled            Boolean   @default(true)
  /// Last time a reminder was sent; cron allows at most one send per Pacific calendar day while still inactive.
  lastReminderSentAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt DateTime @updatedAt
}

model PageVisit {
  id        String   @id @default(cuid())
  userId    String?
  userName  String?
  userEmail String?
  path      String
  visitedAt DateTime @default(now())
}

model PhoneBookEntry {
  id              String   @id @default(cuid())
  sortOrder       Int      @default(0)
  employee        String
  // When true, row appears in the Employees section for users.
  isEmployee      Boolean  @default(true)
  workCell        String   @default("")
  fax             String   @default("")
  extension       String   @default("") // main line ext (888-569-0801 ext.)
  personalEmail   String   @default("")
  personalPhone   String   @default("")
  remarks         String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// Dashboard popup messages (HTML body); one may be active at a time.
model PopupMessage {
  id             String           @id @default(cuid())
  title          String
  body           String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  createdByName  String?
  createdByEmail String?
  dismissals     PopupDismissal[]
}

/// Singleton id `"default"` — which popup message is shown on the dashboard.
model PopupSettings {
  id              String  @id @default("default")
  activePopupId   String?
}

/// User opted out of seeing a popup message ("Do not display again").
model PopupDismissal {
  id             String       @id @default(cuid())
  userEmail      String
  popupMessageId String
  popupUpdatedAt DateTime
  dismissedAt    DateTime     @default(now())
  popupMessage   PopupMessage @relation(fields: [popupMessageId], references: [id], onDelete: Cascade)

  @@unique([userEmail, popupMessageId])
}
